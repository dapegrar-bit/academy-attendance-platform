SECRET_KEY=change-this-secret-key
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# مهم جدًا على Render: لا تستخدم SQLite لحفظ بيانات المتدربين. ضع رابط PostgreSQL هنا.
# تحصل على DATABASE_URL من Render Postgres > Connect > Internal URL
DATABASE_URL=
# مثال فقط: DATABASE_URL=postgresql://user:password@host:5432/dbname
REQUIRE_DATABASE_URL=False

ACADEMY_NAME=أكاديميتي
SYSTEM_NAME=النظام الشامل للحضور والمحاضرات
LOGO_URL=https://i.top4top.io/p_3822gqcjp1.png
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ضع_كلمة_مرور_قوية_هنا
ADMIN_EMAIL=
ADMIN_FULL_NAME=مدير النظام

# لتفعيل البريد الحقيقي
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# رابط قناة التليجرام العامة لتسجيلات المحاضرات
TELEGRAM_CHANNEL_URL=
